# Copy to .env on the VPS for docker compose. Keep this file OUT of git.

# --- Database (used by the db service and built into DATABASE_URL) ---
POSTGRES_USER=fura
POSTGRES_PASSWORD=change-this-to-a-long-random-password
POSTGRES_DB=fura

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-this

# --- Domain / HTTPS (Caddy) ---
DOMAIN=fleet.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# --- First superadmin (used once by: docker compose run --rm app npm run db:seed) ---
SEED_EMAIL=owner@yourdomain.com
SEED_PASSWORD=set-a-strong-password
SEED_NAME=Owner
